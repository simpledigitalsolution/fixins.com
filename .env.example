# GoDaddy cPanel FTP credentials for GitHub Actions deploy
# Add these as GitHub repository secrets on simpledigitalsolution/fixins.com

FTP_SERVER=ftp.fixinsapp.com
FTP_USERNAME=your_ftp_username
FTP_PASSWORD=your_ftp_password

# Build note:
# This workflow expects a Next.js static export in ./out/ (next build with output: "export").
